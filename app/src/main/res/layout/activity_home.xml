<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEFEF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->
        <TextView
            android:id="@+id/textTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Topics of Interest"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="24dp"/>

        <!-- GRID LAYOUT FOR TOPICS -->
        <GridLayout
            android:id="@+id/gridTopics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="true">

            <!-- Topic Buttons with selector -->
            <ToggleButton
                android:id="@+id/btnTech"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:textOn="Tech ✓"
                android:textOff="Tech"
                android:backgroundTint="@color/toggle_selector"
                android:textColor="#1A1A1A"
                android:textSize="16sp"/>

            <ToggleButton
                android:id="@+id/btnSports"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:textOn="Sports ✓"
                android:textOff="Sports"
                android:backgroundTint="@color/toggle_selector"
                android:textColor="#1A1A1A"
                android:textSize="16sp"/>

            <ToggleButton
                android:id="@+id/btnPolitics"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:textOn="Politics ✓"
                android:textOff="Politics"
                android:backgroundTint="@color/toggle_selector"
                android:textColor="#1A1A1A"
                android:textSize="16sp"/>

            <ToggleButton
                android:id="@+id/btnHealth"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:textOn="Health ✓"
                android:textOff="Health"
                android:backgroundTint="@color/toggle_selector"
                android:textColor="#1A1A1A"
                android:textSize="16sp"/>

            <ToggleButton
                android:id="@+id/btnBusiness"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:textOn="Business ✓"
                android:textOff="Business"
                android:backgroundTint="@color/toggle_selector"
                android:textColor="#1A1A1A"
                android:textSize="16sp"/>

            <ToggleButton
                android:id="@+id/btnEntertainment"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:textOn="Entertainment ✓"
                android:textOff="Entertainment"
                android:backgroundTint="@color/toggle_selector"
                android:textColor="#1A1A1A"
                android:textSize="16sp"/>

        </GridLayout>

        <!-- CONTINUE BUTTON -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Continue"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:textStyle="bold"
            android:layout_marginTop="30dp"/>

    </LinearLayout>

</ScrollView>
