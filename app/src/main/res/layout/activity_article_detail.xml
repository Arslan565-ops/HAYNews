<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundMain">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgArticle"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:background="@color/sectionBackground" />

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/textMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/textSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/textCredibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credibility: 87%"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/credibility_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/textContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/textPrimary"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="18dp" />

        <TextView
            android:id="@+id/textReadFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Read full article"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnLike"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/article_action_bg"
                android:src="@drawable/ic_like"
                android:padding="8dp"
                app:tint="@color/primary" />

            <ImageView
                android:id="@+id/btnBookmark"
                android:layout_marginStart="20dp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/article_action_bg"
                android:src="@drawable/ic_bookmark"
                android:padding="8dp"
                app:tint="@color/primary"/>

            <ImageView
                android:id="@+id/btnShare"
                android:layout_marginStart="20dp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/article_action_bg"
                android:src="@drawable/ic_share"
                android:padding="8dp"
                app:tint="@color/primary"/>

            <ImageView
                android:id="@+id/btnDownload"
                android:layout_marginStart="20dp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/article_action_bg"
                android:src="@drawable/ic_download"
                android:padding="8dp"
                app:tint="@color/primary"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
